{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/mobile",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/resource/:path*", "destination": "/resource" },
    { "source": "/guide", "destination": "/guide" }
  ]
}