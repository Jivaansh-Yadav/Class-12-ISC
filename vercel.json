{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/mobile", "destination": "/", "permanent": true },
    { "source": "/mobile.html", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/resource/:path*", "destination": "/resource" },
    { "source": "/guide", "destination": "/guide" }
  ]
}
